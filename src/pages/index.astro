---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';

const indexPost = await getEntry('posts', 'index');

if (!indexPost) {
  return Astro.redirect('/post');
}

const { Content } = await indexPost.render();
const title = indexPost.data.title;
---

<BaseLayout title={title}>
  <div class="reading-continue" id="reading-continue" style="display:none;">
    <a id="reading-continue-link" href="#">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
        <path d="M13 3c-4.97 0-9 4.03-9 9H1l3.89 3.89.07.14L9 12H6c0-3.87 3.13-7 7-7s7 3.13 7 7-3.13 7-7 7c-1.93 0-3.68-.79-4.94-2.06l-1.42 1.42C8.27 19.99 10.51 21 13 21c4.97 0 9-4.03 9-9s-4.03-9-9-9zm-1 5v5l4.25 2.52.77-1.28-3.52-2.09V8z"/>
      </svg>
      <span id="reading-continue-title"></span>
      <span class="reading-continue-section" id="reading-continue-section"></span>
    </a>
  </div>
  <Content />
</BaseLayout>

<script>
  function initReadingContinue() {
    try {
      const saved = localStorage.getItem('reading-last');
      if (!saved) return;
      const data = JSON.parse(saved);
      if (!data.slug || !data.headingId) return;

      const container = document.getElementById('reading-continue');
      const link = document.getElementById('reading-continue-link');
      const titleEl = document.getElementById('reading-continue-title');
      const sectionEl = document.getElementById('reading-continue-section');
      if (!container || !link || !titleEl || !sectionEl) return;

      titleEl.textContent = data.title;
      sectionEl.textContent = `· ${data.headingText}`;
      link.href = `/post/${data.slug}#${data.headingId}`;
      container.style.display = 'block';
    } catch {}
  }

  document.addEventListener('DOMContentLoaded', initReadingContinue);
  document.addEventListener('astro:page-load', initReadingContinue);
</script>

<style>
  .reading-continue {
    margin-bottom: 20px;
    padding: 12px 16px;
    background-color: #f0f7f4;
    border: 1px solid var(--primary-color);
    border-radius: 6px;
    font-size: 14px;
  }

  :global(html.dark) .reading-continue {
    background-color: #1a2a22;
  }

  .reading-continue a {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--primary-color);
    text-decoration: none;
    font-weight: 500;
  }

  .reading-continue a:hover {
    opacity: 0.8;
  }

  .reading-continue-section {
    color: var(--secondary-color);
    font-weight: 400;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
</style>
